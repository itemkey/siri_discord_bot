DISCORD_TOKEN=put-your-bot-token-here

# Optional: set this while developing so slash commands appear instantly in one server.
# Leave empty for global commands, which may take up to an hour to propagate.
GUILD_ID=

# Optional Discord user ID that can use admin commands.
OWNER_ID=

# Optional comma-separated role IDs that can use admin commands.
ADMIN_ROLE_IDS=

COMMAND_PREFIX=!
BOT_STATUS=online
LOG_LEVEL=INFO

# PostgreSQL used by the leveling system.
# In Docker Compose the host is the service name: postgres.
POSTGRES_DB=siri_discord_bot
POSTGRES_USER=siri
POSTGRES_PASSWORD=siri_password_change_me
DATABASE_URL=postgresql://siri:siri_password_change_me@postgres:5432/siri_discord_bot
